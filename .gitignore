/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/
reports/
public/reports/

# Local screenshots and temporary icon/image captures
/*.png
/*.jpg
/*.jpeg
/*.bmp
/tmp_*.*
/_tmp_*.*
/_srv*.*
/_run*.*
/_try_build*.js
/_direct_build.js
/_ng_build.js
/_ng_test.js
