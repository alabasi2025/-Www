ORACLE_CONNECT_STRING=host:1521/service
ORACLE_CLIENT_DIR=C:\oracle\instantclient

# Use either one shared password:
ORACLE_PASSWORD=change-me

# Or set a schema-specific password when schemas differ:
# ORACLE_DATAALA_PASSWORD=change-me
# ORACLE_DATAALF_PASSWORD=change-me

# Optional when the Oracle username is not the lowercase schema name:
# ORACLE_USER=dataala
# ORACLE_DATAALF_USER=dataalf
